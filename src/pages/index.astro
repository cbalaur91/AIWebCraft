---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/ui/hero';
import { Review } from '../components/ui/review';
---

<Layout title="AiWebHub - Professional Web Development Services">
	<main>
		<!-- Hero Section -->
		<Hero client:load />

		<!-- Services Section -->
		<section class="py-20 bg-gray-900">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Our Services
					</span>
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
						<h3 class="text-2xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-4">Professional Landing Pages</h3>
						<p class="text-gray-300 mb-4">Custom-designed, high-converting landing pages optimized for lead generation and sales conversion. Perfect for product launches and marketing campaigns.</p>
						<p class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">Starting at $200</p>
					</div>
					<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
						<h3 class="text-2xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-4">Creative Portfolio Websites</h3>
						<p class="text-gray-300 mb-4">Stunning portfolio websites that showcase your work with modern design, smooth animations, and responsive layouts. Ideal for creatives and professionals.</p>
						<p class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">Starting at $400</p>
					</div>
					<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
						<h3 class="text-2xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-4">Custom Business Websites</h3>
						<p class="text-gray-300 mb-4">Full-featured business websites with SEO optimization, content management, e-commerce capabilities, and AI chatbot integration. Built to drive growth and establish your brand online.</p>
						<p class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">Starting at $800</p>
					</div>
				</div>
				<div class="mt-12 text-center">
					<h3 class="text-2xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-4">AI Integration Services</h3>
					<p class="text-gray-300 max-w-2xl mx-auto">
						Enhance your website with cutting-edge AI capabilities. We specialize in integrating intelligent chatbots and AI agents to provide 24/7 customer support, automate tasks, and create personalized user experiences.
					</p>
				</div>
			</div>
		</section>

		<!-- Divider -->
		<div class="relative">
			<div class="absolute inset-0 bg-gradient-to-b from-gray-900 to-gray-800"></div>
			<div class="absolute inset-0 opacity-30">
				<div class="h-full w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
			</div>
			<div class="h-24 relative">
				<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:linear-gradient(0deg,transparent,black)]"></div>
			</div>
		</div>

		<!-- Process Section -->
		<section class="py-20 bg-gray-800">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Our Process
					</span>
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div class="text-center">
						<div class="w-16 h-16 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
							<span class="text-2xl font-bold text-white">1</span>
						</div>
						<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-2">Discovery</h3>
						<p class="text-gray-300">Understanding your needs and goals</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
							<span class="text-2xl font-bold text-white">2</span>
						</div>
						<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-2">Design</h3>
						<p class="text-gray-300">Creating the perfect look for your brand</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
							<span class="text-2xl font-bold text-white">3</span>
						</div>
						<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-2">Development</h3>
						<p class="text-gray-300">Building your website with care</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
							<span class="text-2xl font-bold text-white">4</span>
						</div>
						<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-2">Launch</h3>
						<p class="text-gray-300">Going live with your new website</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Divider -->
		<div class="relative">
			<div class="absolute inset-0 bg-gradient-to-b from-gray-800 to-gray-900"></div>
			<div class="absolute inset-0 opacity-30">
				<div class="h-full w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
			</div>
			<div class="h-24 relative">
				<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:linear-gradient(0deg,transparent,black)]"></div>
			</div>
		</div>

		<!-- Review Section -->
		<Review client:load />

		<!-- Divider -->
		<div class="relative">
			<div class="absolute inset-0 bg-gradient-to-b from-gray-900 to-gray-800"></div>
			<div class="absolute inset-0 opacity-30">
				<div class="h-full w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
			</div>
			<div class="h-24 relative">
				<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:linear-gradient(0deg,transparent,black)]"></div>
			</div>
		</div>

		<!-- CTA Section -->
		<section class="py-20 bg-gray-800">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-4xl font-bold mb-6">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Ready to Get Started?
					</span>
				</h2>
				<p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
					Let's create something amazing together. Contact us today for a free consultation.
				</p>
				<a 
					href="/contact" 
					class="bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 text-white px-8 py-3 rounded-lg hover:opacity-90 transition inline-block"
				>
					Contact Us
				</a>
			</div>
		</section>
	</main>
</Layout>