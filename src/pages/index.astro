---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/ui/hero';
import { Review } from '../components/ui/review';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';
import { Icon } from 'astro-icon/components';
---

<Layout title="AiWebHub - Professional Web Development Services">
	<main>
		<!-- Hero Section -->
		<Hero client:load />

		<!-- Services Section -->
		<section class="py-20 bg-gray-900">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Our Services
					</span>
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<Card>
						<CardHeader>
							<div class="flex items-center gap-4 mb-2">
								<Icon name="lucide:target" class="w-8 h-8 text-purple-400" />
								<CardTitle class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400">Professional Landing Pages</CardTitle>
							</div>
						</CardHeader>
						<CardContent>
							<CardDescription class="mb-4">Custom-designed, high-converting landing pages optimized for lead generation and sales conversion. Perfect for product launches and marketing campaigns.</CardDescription>
						</CardContent>
					</Card>
					<Card>
						<CardHeader>
							<div class="flex items-center gap-4 mb-2">
								<Icon name="lucide:palette" class="w-8 h-8 text-purple-400" />
								<CardTitle class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400">Creative Portfolio Websites</CardTitle>
							</div>
						</CardHeader>
						<CardContent>
							<CardDescription class="mb-4">Stunning portfolio websites that showcase your work with modern design, smooth animations, and responsive layouts. Ideal for creatives and professionals.</CardDescription>
						</CardContent>
					</Card>
					<Card>
						<CardHeader>
							<div class="flex items-center gap-4 mb-2">
								<Icon name="lucide:building" class="w-8 h-8 text-purple-400" />
								<CardTitle class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400">Custom Business Websites</CardTitle>
							</div>
						</CardHeader>
						<CardContent>
							<CardDescription class="mb-4">Full-featured business websites with SEO optimization, content management, e-commerce capabilities, and AI chatbot integration. Built to drive growth and establish your brand online.</CardDescription>
						</CardContent>
					</Card>
				</div>
				<div class="mt-12 text-center">
					<h3 class="flex items-center justify-center gap-2 text-2xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-4">
						<Icon name="lucide:bot" class="w-6 h-6" /> AI Integration Services
					</h3>
					<p class="text-gray-300 max-w-2xl mx-auto">
						Enhance your website with cutting-edge AI capabilities. We specialize in integrating intelligent chatbots and AI agents to provide 24/7 customer support, automate tasks, and create personalized user experiences.
					</p>
				</div>
			</div>
		</section>

		<!-- Divider -->
		<div class="relative">
			<div class="absolute inset-0 bg-gradient-to-b from-gray-900 to-gray-800"></div>
			<div class="absolute inset-0 opacity-30">
				<div class="h-full w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
			</div>
			<div class="h-24 relative">
				<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:linear-gradient(0deg,transparent,black)]"></div>
			</div>
		</div>

		<!-- Process Section -->
		<section class="py-20 bg-gray-800">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Our Process
					</span>
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div class="text-center">
						<div class="w-16 h-16 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
							<Icon name="lucide:search" class="w-8 h-8 text-white" />
						</div>
						<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-2">Discovery</h3>
						<p class="text-gray-300">Understanding your needs and goals</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
							<Icon name="lucide:palette" class="w-8 h-8 text-white" />
						</div>
						<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-2">Design</h3>
						<p class="text-gray-300">Creating the perfect look for your brand</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
							<Icon name="lucide:code" class="w-8 h-8 text-white" />
						</div>
						<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-2">Development</h3>
						<p class="text-gray-300">Building your website with care</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
							<Icon name="lucide:rocket" class="w-8 h-8 text-white" />
						</div>
						<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-2">Launch</h3>
						<p class="text-gray-300">Going live with your new website</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Divider -->
		<div class="relative">
			<div class="absolute inset-0 bg-gradient-to-b from-gray-800 to-gray-900"></div>
			<div class="absolute inset-0 opacity-30">
				<div class="h-full w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
			</div>
			<div class="h-24 relative">
				<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:linear-gradient(0deg,transparent,black)]"></div>
			</div>
		</div>

		<!-- Review Section -->
		<Review client:load />

		<!-- Divider -->
		<div class="relative">
			<div class="absolute inset-0 bg-gradient-to-b from-gray-900 to-gray-800"></div>
			<div class="absolute inset-0 opacity-30">
				<div class="h-full w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
			</div>
			<div class="h-24 relative">
				<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:linear-gradient(0deg,transparent,black)]"></div>
			</div>
		</div>

		<!-- CTA Section -->
		<section class="py-20 bg-gray-800">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-4xl font-bold mb-6">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Ready to Get Started?
					</span>
				</h2>
				<p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
					Let's create something amazing together. Contact us today for a free consultation.
				</p>
				<a 
					href="/contact" 
					class="bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 text-white px-8 py-3 rounded-lg hover:opacity-90 transition inline-flex items-center gap-2"
				>
					<Icon name="lucide:send" class="w-5 h-5" /> Contact Us
				</a>
			</div>
		</section>
	</main>
</Layout>