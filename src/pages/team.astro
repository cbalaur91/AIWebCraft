---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: "Cosmin Balaur",
    role: "Full-Stack Developer",
    image: "/team/Cosmin.png",
    bio: "Cosmin specializes in building scalable web applications with modern technologies. His expertise in both front-end and back-end development ensures seamless, full-stack solutions."
  },
  {
    name: "Bogdan Balaur",
    role: "DevSecOps Engineer",
    image: "/team/Bogdan.jpg",
    bio: "Bogdan brings extensive experience in implementing secure and efficient DevSecOps practices. His focus on automation, security integration, and performance optimization ensures robust and resilient software delivery for our clients."
  }
];
---

<Layout title="Our Team - WebCraft">
	<main class="pt-20">
		<section class="relative py-20 bg-gray-900 overflow-hidden">
			<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:radial-gradient(ellipse_at_center,transparent_20%,black)]" />
			<div class="container mx-auto px-4">
				<h1 class="text-5xl font-bold text-center mb-6">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Meet Our Team
					</span>
				</h1>
				<p class="text-xl text-gray-300 text-center max-w-3xl mx-auto mb-16">
					Our talented team of developers and designers are passionate about creating exceptional web experiences.
				</p>
				<div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
					{team.map((member) => (
						<div class="bg-gray-800/50 rounded-lg overflow-hidden backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
							<div class="relative">
								<div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 via-purple-500/20 to-pink-500/20 blur-xl"></div>
								<img src={member.image} alt={member.name} class="w-full h-68 object-cover relative" />
							</div>
							<div class="p-6">
								<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400">{member.name}</h3>
								<p class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400 mt-1">{member.role}</p>
								<p class="text-gray-300 mt-4">{member.bio}</p>
							</div>
						</div>
					))}
				</div>

				<div class="relative max-w-3xl mx-auto text-center">
					<div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-pink-500/10 blur-3xl -z-10" />
					<h2 class="text-3xl font-bold mb-6">
						<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
							Join Our Team
						</span>
					</h2>
					<p class="text-gray-300 mb-8">
						We're always looking for talented developers and designers to join our team. 
						If you're passionate about creating exceptional web experiences, we'd love to hear from you.
					</p>
					<a 
						href="/contact" 
						class="bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 text-white px-8 py-3 rounded-lg hover:opacity-90 transition inline-block"
					>
						Get in Touch
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>