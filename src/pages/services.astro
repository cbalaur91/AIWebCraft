---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/ui/button';
import { Icon } from 'astro-icon/components';
import { Card, CardHeader, CardTitle, CardContent, CardDescription } from '@/components/ui/card';

const title = "Professional Web Development Services - AiWebHub";
const description = "Comprehensive web development services including custom websites, landing pages, and e-commerce solutions. Expert development, SEO optimization, and responsive design.";
import { motion } from 'framer-motion';
---

<Layout title={title}>
	<main class="pt-20">
		<!-- Hero Section -->
		<section class="relative py-20 bg-gray-900 overflow-hidden">
			<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:radial-gradient(ellipse_at_center,transparent_20%,black)]" />
			<div class="container mx-auto px-4">
				<h1 class="text-5xl font-bold text-center mb-12">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Our Services
					</span>
				</h1>
				<p class="text-xl text-gray-300 text-center max-w-3xl mx-auto mb-16">
					We offer comprehensive web development solutions tailored to your needs. 
					Choose the perfect package to establish your online presence.
				</p>
				
				<div class="grid grid-cols-1 gap-24">
					<!-- Landing Pages -->
					<div class="relative">
						<div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-pink-500/10 blur-3xl -z-10"></div>
						<div class="flex flex-col gap-8">
							<div class="text-center">
								<h2 class="text-3xl font-bold mb-6">
									<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400">
										Landing Pages
									</span>
								</h2>
							</div>
							<div class="grid md:grid-cols-2 gap-8 items-center">
								<Card>
									<CardHeader>
										<CardTitle class="text-white">Modern, High-Quality Landing Pages</CardTitle>
									</CardHeader>
									<CardContent>
										<ul class="text-gray-300 space-y-3 mb-6">
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Clean and simple UI design
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												SEO-optimized for better search rankings
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Smooth animations and modern effects
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Mobile-friendly and fast loading
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												3 rounds of revisions to perfect your site
											</li>
										</ul>
									</CardContent>
								</Card>
								<div class="relative">
									<div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 via-purple-500/20 to-pink-500/20 blur-xl rounded-lg"></div>
									<img 
										src="landingpage.jpg" 
										alt="Landing Page Example" 
										class="rounded-lg shadow-2xl relative"
									/>
								</div>
							</div>
						</div>
					</div>
					<!-- Portfolio Sites -->
					<div class="relative">
						<div class="absolute inset-0 bg-gradient-to-r from-purple-500/10 via-pink-500/10 to-blue-500/10 blur-3xl -z-10"></div>
						<div class="flex flex-col gap-8">
							<div class="text-center">
								<h2 class="text-3xl font-bold mb-6">
									<span class="bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-pink-400">
										Portfolio Sites
									</span>
								</h2>
							</div>
							<div class="grid md:grid-cols-2 gap-8 items-center">
								<Card>
									<CardHeader>
										<CardTitle class="text-white">Professional Portfolio</CardTitle>
									</CardHeader>
									<CardContent>
										<ul class="text-gray-300 space-y-3 mb-6">
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Personalized portfolio design tailored to your style
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Easy-to-use project showcase to highlight your work
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Fast and efficient image optimization for better performance
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Simple contact form integration for easy communication
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												3 rounds of revisions to ensure your satisfaction
											</li>
										</ul>
									</CardContent>
								</Card>
								<div class="relative">
									<div class="absolute inset-0 bg-gradient-to-r from-purple-500/20 via-pink-500/20 to-blue-500/20 blur-xl rounded-lg"></div>
									<img 
										src="portfolio.jpg" 
										alt="Portfolio Example" 
										class="rounded-lg shadow-2xl relative"
									/>
								</div>
							</div>
						</div>
					</div>

					<!-- Business Websites -->
					<div class="relative">
						<div class="absolute inset-0 bg-gradient-to-r from-pink-500/10 via-blue-500/10 to-purple-500/10 blur-3xl -z-10"></div>
						<div class="flex flex-col gap-8">
							<div class="text-center">
								<h2 class="text-3xl font-bold mb-6">
									<span class="bg-clip-text text-transparent bg-gradient-to-r from-pink-400 to-blue-400">
										Business Websites
									</span>
								</h2>
							</div>
							<div class="grid md:grid-cols-2 gap-8 items-center">
								<div class="space-y-6">
									<Card>
										<CardHeader>
											<CardTitle class="text-white">Basic Package</CardTitle>
										</CardHeader>
										<CardContent>
											<ul class="text-gray-300 space-y-3 mb-6">
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Up to 5 custom pages
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Mobile responsive design
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Basic database integration for managing content
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Basic AI chatbot integration
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Simple log-in functionality for user access
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													3 rounds of revisions
												</li>
											</ul>
										</CardContent>
									</Card>
									<Card>
										<CardHeader>
											<CardTitle class="text-white">Premium Package</CardTitle>
										</CardHeader>
										<CardContent>
											<ul class="text-gray-300 space-y-3 mb-6">
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Up to 10 fully customized pages
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Advanced database integration for seamless content management
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Secure log-in functionality for user authentication
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Advanced AI integration (chatbots & agents)
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													Custom forms and third-party integrations
												</li>
												<li class="flex items-center">
													<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
													4 rounds of revisions
												</li>
											</ul>
										</CardContent>
									</Card>
								</div>
								<div class="relative">
									<div class="absolute inset-0 bg-gradient-to-r from-pink-500/20 via-blue-500/20 to-purple-500/20 blur-xl rounded-lg"></div>
									<img 
										src="business.jpg" 
										alt="Business Website Example" 
										class="rounded-lg shadow-2xl relative"
									/>
								</div>
							</div>
						</div>
					</div>

					<!-- AI Services -->
					<div class="relative mt-20">
						<div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-pink-500/10 blur-3xl -z-10"></div>
						<div class="flex flex-col gap-8">
							<div class="text-center">
								<h2 class="text-3xl font-bold mb-6">
									<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400">
										AI Integration Services
									</span>
								</h2>
							</div>
							<div class="grid md:grid-cols-2 gap-8 items-center">
								<Card>
									<CardHeader>
										<CardTitle class="text-white">AI Solutions</CardTitle>
									</CardHeader>
									<CardContent>
										<ul class="text-gray-300 space-y-3 mb-6">
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Custom AI chatbot development
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Intelligent AI agents integration
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												24/7 automated customer support
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Natural language processing
											</li>
											<li class="flex items-center">
												<Icon name="lucide:check" class="w-5 h-5 mr-3 text-green-500 flex-shrink-0" />
												Personalized user interactions
											</li>
										</ul>
									</CardContent>
								</Card>
								<div class="relative">
									<div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 via-purple-500/20 to-pink-500/20 blur-xl rounded-lg"></div>
									<img 
										src="https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3" 
										alt="AI Integration Example" 
										class="rounded-lg shadow-2xl relative"
									/>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 bg-gray-800">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-4xl font-bold mb-6">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Ready to Transform Your Online Presence?
					</span>
				</h2>
				<p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
					Let's discuss your project and create something amazing together. Contact us today for a free consultation.
				</p>
				<Button asChild className="bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 hover:opacity-90 transition">
					<a href="/contact">
						<Icon name="lucide:send" class="w-5 h-5 mr-2" /> Get Started
					</a>
				</Button>
			</div>
		</section>
	</main>
</Layout>