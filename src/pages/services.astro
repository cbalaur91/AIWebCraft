---
import Layout from '../layouts/Layout.astro';

const title = "Professional Web Development Services - WebCraft";
const description = "Comprehensive web development services including custom websites, landing pages, and e-commerce solutions. Expert development, SEO optimization, and responsive design.";
import { motion } from 'framer-motion';
---

<Layout title={title}>
	<main class="pt-20">
		<!-- Hero Section -->
		<section class="relative py-20 bg-gray-900 overflow-hidden">
			<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:radial-gradient(ellipse_at_center,transparent_20%,black)]" />
			<div class="container mx-auto px-4">
				<h1 class="text-5xl font-bold text-center mb-12">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Our Services
					</span>
				</h1>
				<p class="text-xl text-gray-300 text-center max-w-3xl mx-auto mb-16">
					We offer comprehensive web development solutions tailored to your needs. 
					Choose the perfect package to establish your online presence.
				</p>
				
				<div class="grid grid-cols-1 gap-24">
					<!-- Landing Pages -->
					<div class="relative">
						<div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-pink-500/10 blur-3xl -z-10"></div>
						<div class="flex flex-col gap-8">
							<div class="text-center">
								<h2 class="text-3xl font-bold mb-6">
									<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400">
										Landing Pages
									</span>
								</h2>
							</div>
							<div class="grid md:grid-cols-2 gap-8 items-center">
								<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
									<h3 class="text-2xl font-semibold text-white mb-4">High-Converting Landing Pages</h3>
									<ul class="text-gray-300 space-y-3 mb-6">
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											Conversion-optimized design
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											A/B testing setup
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											Lead capture forms
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											Analytics integration
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											3 rounds of revisions
										</li>
									</ul>
									<p class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400 text-xl font-semibold">Starting at $300</p>
								</div>
								<div class="relative">
									<div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 via-purple-500/20 to-pink-500/20 blur-xl rounded-lg"></div>
									<img 
										src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3" 
										alt="Landing Page Example" 
										class="rounded-lg shadow-2xl relative"
									/>
								</div>
							</div>
						</div>
					</div>
					<!-- Portfolio Sites -->
					<div class="relative">
						<div class="absolute inset-0 bg-gradient-to-r from-purple-500/10 via-pink-500/10 to-blue-500/10 blur-3xl -z-10"></div>
						<div class="flex flex-col gap-8">
							<div class="text-center">
								<h2 class="text-3xl font-bold mb-6">
									<span class="bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-pink-400">
										Portfolio Sites
									</span>
								</h2>
							</div>
							<div class="grid md:grid-cols-2 gap-8 items-center">
								<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
									<h3 class="text-2xl font-semibold text-white mb-4">Professional Portfolio</h3>
									<ul class="text-gray-300 space-y-3 mb-6">
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 flex items-center justify-center">✓</span>
											Custom portfolio layout
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 flex items-center justify-center">✓</span>
											Project showcase features
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 flex items-center justify-center">✓</span>
											Image optimization
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 flex items-center justify-center">✓</span>
											Contact integration
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 flex items-center justify-center">✓</span>
											3 rounds of revisions
										</li>
									</ul>
									<p class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-blue-400 text-xl font-semibold">Starting at $400</p>
								</div>
								<div class="relative">
									<div class="absolute inset-0 bg-gradient-to-r from-purple-500/20 via-pink-500/20 to-blue-500/20 blur-xl rounded-lg"></div>
									<img 
										src="https://images.unsplash.com/photo-1487014679447-9f8336841d58?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3" 
										alt="Portfolio Example" 
										class="rounded-lg shadow-2xl relative"
									/>
								</div>
							</div>
						</div>
					</div>

					<!-- Business Websites -->
					<div class="relative">
						<div class="absolute inset-0 bg-gradient-to-r from-pink-500/10 via-blue-500/10 to-purple-500/10 blur-3xl -z-10"></div>
						<div class="flex flex-col gap-8">
							<div class="text-center">
								<h2 class="text-3xl font-bold mb-6">
									<span class="bg-clip-text text-transparent bg-gradient-to-r from-pink-400 to-blue-400">
										Business Websites
									</span>
								</h2>
							</div>
							<div class="grid md:grid-cols-2 gap-8 items-center">
								<div class="space-y-6">
									<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
										<h3 class="text-2xl font-semibold text-white mb-4">Basic Package</h3>
										<ul class="text-gray-300 space-y-3 mb-6">
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Up to 5 pages
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Mobile responsive design
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Basic SEO setup
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Basic AI chatbot integration
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Contact form
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												2 rounds of revisions
											</li>
										</ul>
										<p class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400 text-xl font-semibold">Starting at $500</p>
									</div>
									<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
										<h3 class="text-2xl font-semibold text-white mb-4">Premium Package</h3>
										<ul class="text-gray-300 space-y-3 mb-6">
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Up to 10 pages
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Advanced design features
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Advanced SEO optimization
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Advanced AI integration (chatbots & agents)
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												Custom forms and integrations
											</li>
											<li class="flex items-center">
												<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-pink-500 to-blue-500 flex items-center justify-center">✓</span>
												4 rounds of revisions
											</li>
										</ul>
										<p class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400 text-xl font-semibold">Starting at $1000</p>
									</div>
								</div>
								<div class="relative">
									<div class="absolute inset-0 bg-gradient-to-r from-pink-500/20 via-blue-500/20 to-purple-500/20 blur-xl rounded-lg"></div>
									<img 
										src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3" 
										alt="Business Website Example" 
										class="rounded-lg shadow-2xl relative"
									/>
								</div>
							</div>
						</div>
					</div>

					<!-- AI Services -->
					<div class="relative mt-20">
						<div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-pink-500/10 blur-3xl -z-10"></div>
						<div class="flex flex-col gap-8">
							<div class="text-center">
								<h2 class="text-3xl font-bold mb-6">
									<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400">
										AI Integration Services
									</span>
								</h2>
							</div>
							<div class="grid md:grid-cols-2 gap-8 items-center">
								<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
									<h3 class="text-2xl font-semibold text-white mb-4">AI Solutions</h3>
									<ul class="text-gray-300 space-y-3 mb-6">
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											Custom AI chatbot development
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											Intelligent AI agents integration
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											24/7 automated customer support
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											Natural language processing
										</li>
										<li class="flex items-center">
											<span class="w-5 h-5 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center">✓</span>
											Personalized user interactions
										</li>
									</ul>
									<p class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400 text-xl font-semibold">Starting at $300</p>
								</div>
								<div class="relative">
									<div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 via-purple-500/20 to-pink-500/20 blur-xl rounded-lg"></div>
									<img 
										src="https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3" 
										alt="AI Integration Example" 
										class="rounded-lg shadow-2xl relative"
									/>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 bg-gray-800">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-4xl font-bold mb-6">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Ready to Transform Your Online Presence?
					</span>
				</h2>
				<p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
					Let's discuss your project and create something amazing together. Contact us today for a free consultation.
				</p>
				<a 
					href="/contact" 
					class="bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 text-white px-8 py-3 rounded-lg hover:opacity-90 transition inline-block"
				>
					Get Started
				</a>
			</div>
		</section>
	</main>
</Layout>