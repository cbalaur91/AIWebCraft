---
import Layout from '../layouts/Layout.astro';

const title = "About AiWebHub - Professional Web Development Agency";
const description = "Learn about AiWebHub's expert web development team, our mission, and how we help businesses succeed online through custom web solutions.";
---

<Layout title={title}>
	<main class="pt-20">
		<section class="relative py-20 bg-gray-900 overflow-hidden">
			<div class="absolute inset-0 bg-grid-white/[0.2] [mask-image:radial-gradient(ellipse_at_center,transparent_20%,black)]" />
			<div class="container mx-auto px-4">
				<h1 class="text-5xl font-bold text-center mb-6">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						About AiWebHub
					</span>
				</h1>
				
				<div class="relative max-w-3xl mx-auto text-gray-300 space-y-6 mb-20">
					<div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-pink-500/10 blur-3xl -z-10" />
					<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
					<p class="mb-4">
						Founded in 2024, AiWebHub is a leading web development agency dedicated to helping startups and businesses establish a powerful online presence through custom-built, SEO-optimized websites.
					</p>
					<p class="mb-4">
						Our mission is to make professional web development accessible to businesses of all sizes. We combine cutting-edge technology with strategic design to create websites that drive growth and deliver measurable results.
					</p>
					<p>
						What sets us apart is our commitment to:
					</p>
					<ul class="list-disc pl-6 space-y-2">
						<li>Custom web solutions tailored to your business goals</li>
						<li>SEO-optimized development for maximum visibility</li>
						<li>Responsive design for all devices and platforms</li>
						<li>Performance optimization and security best practices</li>
						<li>Comprehensive support and maintenance services</li>
					</ul>
					</div>
				</div>

				<div class="relative mt-20">
					<h2 class="text-3xl font-bold text-center mb-8">
						<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
							Why Choose Us?
						</span>
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
							<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-400 mb-4">Expertise</h3>
							<p class="text-gray-300">Our team brings years of experience in web development and design, ensuring your project is in capable hands.</p>
						</div>
						<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
							<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-pink-400 mb-4">Affordability</h3>
							<p class="text-gray-300">We offer competitive pricing without compromising on quality, making professional web development accessible.</p>
						</div>
						<div class="bg-gray-800/50 p-8 rounded-lg backdrop-blur-sm border border-gray-700/50 hover:border-purple-500/50 transition-all duration-300">
							<h3 class="text-xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-pink-400 to-blue-400 mb-4">Support</h3>
							<p class="text-gray-300">We provide ongoing support and maintenance to ensure your website continues to perform at its best.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 bg-gray-800">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-4xl font-bold mb-6">
					<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 animate-gradient">
						Ready to Work Together?
					</span>
				</h2>
				<p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
					Let's create something amazing together. Contact us today to start your journey.
				</p>
				<a 
					href="/contact" 
					class="bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 text-white px-8 py-3 rounded-lg hover:opacity-90 transition inline-block"
				>
					Get Started
				</a>
			</div>
		</section>
	</main>
</Layout>